# Шаблон переменных окружения. Скопируй в .env и заполни.
# .env в .gitignore — реальные значения НЕ коммитим.

# ── Рантайм клиента (статика на GitHub Pages) ──
# Публичные значения, безопасны в браузерном бандле. Защита — через RLS.
# Project URL берётся из ref проекта: https://<ref>.supabase.co
VITE_SUPABASE_URL=https://cfyfpifbjvldvscnyxtk.supabase.co
# anon public ключ: Supabase Dashboard → Project Settings → API → "anon public"
VITE_SUPABASE_ANON_KEY=

# ── ТОЛЬКО для локальной накатки схемы (supabase/schema.sql) ──
# СЕКРЕТ: содержит пароль БД. Используется локально (psql), в браузер НЕ попадает.
# Не присылать в чат и не коммитить. Пароль — в Dashboard → Settings → Database.
DATABASE_URL=postgresql://postgres.cfyfpifbjvldvscnyxtk:[YOUR-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres
